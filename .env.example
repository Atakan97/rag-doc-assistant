# ============================================================
# RAG Documentation Assistant — Environment Variables Template
# Copy this file to .env and fill in your actual values
# ============================================================

# --- Supabase (required for backend + ingestion) ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# --- Groq LLM (required for backend) ---
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=llama-3.1-8b-instant

# --- Embedding model (used by both backend + ingestion) ---
EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- RAG retrieval settings ---
TOP_K=6

# --- CORS (set to your Vercel frontend URL for production) ---
CORS_ORIGINS=http://localhost:3000

# --- Optional: Ollama for local high-quality mode ---
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b-instruct

# --- Ingestion settings (used only by ingest script) ---
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# --- Frontend (set in Vercel dashboard for production) ---
# NEXT_PUBLIC_API_URL=https://your-hf-space.hf.space
